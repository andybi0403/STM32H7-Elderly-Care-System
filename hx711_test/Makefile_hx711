# Makefile for HX711 + LCD — STM32H7R3 (SRAM run)

PREFIX  ?= C:/arm-gcc/bin/arm-none-eabi-
CC      = $(PREFIX)gcc
AS      = $(PREFIX)gcc -x assembler-with-cpp
SZ      = $(PREFIX)size
OBJCOPY = $(PREFIX)objcopy

TARGET    = hx711_lcd
BUILD_DIR = build

STARTUP_S = ../virtual\ UI/Drivers/CMSIS/Device/ST/STM32H7RSxx/Source/Templates/gcc/startup_stm32h7r3xx.s

LCD_UI_C = ../virtual\ UI/UI/lcd_ui.c
C_SRCS  = main_hx711.c Boot/Core/Src/system_stm32h7rsxx.c
OBJS    = $(addprefix $(BUILD_DIR)/, main_hx711.o system_stm32h7rsxx.o) \
          $(BUILD_DIR)/lcd_ui.o $(BUILD_DIR)/startup_stm32h7r3xx.o

MCU    = -mcpu=cortex-m7 -mthumb -mfpu=fpv5-sp-d16 -mfloat-abi=hard
DEFS   = -DSTM32H7R3xx
INC    = -I. -I../virtual\ UI/UI -I../virtual\ UI/Boot/Core/Inc
OPT    = -Og
CFLAGS = $(MCU) $(DEFS) $(INC) $(OPT) -Wall -fdata-sections -ffunction-sections -std=gnu11
LDFLAGS = $(MCU) -specs=nosys.specs -specs=nano.specs -T STM32H7R3L8_SRAM.ld \
          -lc -lm -lnosys -Wl,--gc-sections

.PHONY: all clean

all: $(BUILD_DIR)/$(TARGET).elf
	@echo === Build Complete ===
	$(SZ) $<
	$(OBJCOPY) -O binary $< $(BUILD_DIR)/$(TARGET).bin

$(BUILD_DIR):
	mkdir -p $@

$(BUILD_DIR)/$(TARGET).elf: $(OBJS) | $(BUILD_DIR)
	$(CC) $^ $(LDFLAGS) -o $@

$(BUILD_DIR)/main_hx711.o: main_hx711.c | $(BUILD_DIR)
	$(CC) -c $(CFLAGS) $< -o $@

$(BUILD_DIR)/lcd_ui.o: $(LCD_UI_C) | $(BUILD_DIR)
	$(CC) -c $(CFLAGS) "$<" -o $@

$(BUILD_DIR)/system_stm32h7rsxx.o: Boot/Core/Src/system_stm32h7rsxx.c | $(BUILD_DIR)
	$(CC) -c $(CFLAGS) $< -o $@

$(BUILD_DIR)/startup_stm32h7r3xx.o: $(STARTUP_S) | $(BUILD_DIR)
	$(AS) -c $(MCU) "$<" -o $@

clean:
	rm -rf $(BUILD_DIR)
